rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ADMIN UIDs: replace the placeholder values with the UID(s) of
    // your admin account(s). You can find a user's UID in the
    // Firebase Console → Authentication after creating/signing in.
    // Example: ['uid1Example', 'uid2Example']
    // IMPORTANT: do not commit real UIDs to public repos if this
    // repository is public.
    // NOTE: Firestore rules do not support top-level `let` declarations,
    // so we keep the UID list inline inside the `isAdmin()` function.
    function isAdmin() {
      return request.auth != null && request.auth.uid in ['REPLACE_WITH_ADMIN_UID']
    }

    // Basic validation for incoming registration documents created from the client.
    function isValidRegistration(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'email', 'phone'])
        && data.firstName is string
        && data.lastName is string
        && data.email is string
        && data.phone is string
        // optional fields type checks
        && (!('dateOfBirth' in data) || data.dateOfBirth is string)
        && (!('position' in data) || data.position is string)
        && (!('experience' in data) || data.experience is string)
        && (!('parentName' in data) || data.parentName is string)
        && (!('parentPhone' in data) || data.parentPhone is string)
        && (!('message' in data) || data.message is string)
        && (!('paymentPlan' in data) || data.paymentPlan is string)
        && (!('paymentAmount' in data) || data.paymentAmount is number)
        && (!('paymentStatus' in data) || data.paymentStatus is string)
    }

    // Allow public creation of registrations (written by the web form).
    // Do not allow updates/deletes by clients.
    match /campRegistrations/{regId} {
      allow create: if isValidRegistration(request.resource.data);

      // Allow any authenticated user to read registrations.
      // Allow authenticated users to update only payment fields (paid status/amount).
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'paymentAmount']);
      // Deletes remain admin-only.
      allow delete: if isAdmin();

      // If you'd prefer to allow any authenticated user to read
      // registrations temporarily (NOT recommended for production),
      // replace the `allow read` line above with:
      //   allow read: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}